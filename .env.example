# Database (Neon)
# For Neon (serverless, cold starts + cross-region latency), append
#   &connect_timeout=30&pool_timeout=30
# so the first connection after idle doesn't ETIMEDOUT.
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# Auth.js
AUTH_SECRET=""
# Trust the forwarded Host behind a reverse proxy (campus sandbox / self-host).
# Without this, Auth.js v5 throws UntrustedHost on non-localhost domains.
AUTH_TRUST_HOST="true"

# Cloudflare R2
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_PUBLIC="inform-trade-public"
R2_BUCKET_PRIVATE="inform-trade-private"
NEXT_PUBLIC_R2_PUBLIC_BASE_URL="https://pub.example.com"

# First admin
ADMIN_EMAIL=""

# Cron (Vercel) - shared secret to protect cron endpoint
CRON_SECRET=""

# Sandbox path prefix (boxset branch only): e.g. /apps/<app-name>; empty for local/normal deploy.
BASE_PATH=""
