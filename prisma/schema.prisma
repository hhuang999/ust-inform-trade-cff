generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ───────────────────────── Existing P0 (auth/verification/notifications) ─────────────────────────

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum Role {
  USER
  ADMIN
}

model User {
  id                  String             @id @default(cuid())
  email               String?            @unique
  phone               String?            @unique
  passwordHash        String
  realName            String
  studentId           String
  department          String
  enrollmentYear      Int
  nickname            String
  avatarKey           String?
  realNameVisible     Boolean            @default(false)
  verificationStatus  VerificationStatus @default(UNVERIFIED)
  violationCount      Int                @default(0)
  role                Role               @default(USER)
  disabled            Boolean            @default(false)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  deletedAt           DateTime?

  verificationRequests VerificationRequest[]
  notifications        Notification[]

  // Item panel
  items            Item[]
  itemInterests    ItemInterest[]
  itemDealsSeller  ItemDeal[] @relation("ItemDealSeller")
  itemDealsBuyer   ItemDeal[] @relation("ItemDealBuyer")
  favorites        Favorite[]

  // Service panel
  services             Service[]
  bookingsClient       Booking[] @relation("BookingClient")
  needs                Need[]
  needMatchesProvider  NeedMatch[] @relation("NeedMatchProvider")

  // Cross-cutting
  reviewsGiven    Review[]   @relation("ReviewReviewer")
  reviewsReceived Review[]   @relation("ReviewReviewee")
  reportsFiled    Report[]
  violations      Violation[]
  feedbacks       Feedback[]

  // 站内私信(仅交易关系方之间)
  messagesSent     Message[] @relation("MessageSender")
  messagesReceived Message[] @relation("MessageRecipient")

  @@index([verificationStatus])
}

enum VerificationReqStatus {
  PENDING
  APPROVED
  REJECTED
}

model VerificationRequest {
  id          String                @id @default(cuid())
  userId      String
  photoKeys   String[]
  status      VerificationReqStatus @default(PENDING)
  reviewerId  String?
  reason      String?
  submittedAt DateTime              @default(now())
  reviewedAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, submittedAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String
  link      String?
  data      Json?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt])
}

// ───────────────────────── Contact visibility (shared) ─────────────────────────

enum ContactVisibility {
  VERIFIED_ONLY
  ALL
}

// ───────────────────────── Item panel (二手物品) ─────────────────────────

enum ItemStatus {
  AVAILABLE
  PENDING
  SOLD
  CLOSED
}

enum PriceMode {
  SPECIFIC
  FREE
  NEGOTIABLE
}

model Item {
  id                String          @id @default(cuid())
  sellerId          String
  title             String
  description       String
  category          String
  condition         String
  priceMode         PriceMode       @default(SPECIFIC)
  price             Int?
  originalPrice     Int?
  imageKeys         String[]
  tags              String[]
  tradeMethods      String[]
  pickupLocation    String?
  contactInfo       String
  contactVisibility ContactVisibility @default(VERIFIED_ONLY)
  status            ItemStatus      @default(AVAILABLE)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  deletedAt         DateTime?

  seller    User           @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  interests ItemInterest[]
  deal      ItemDeal?

  @@index([status, createdAt])
  @@index([sellerId])
  @@index([category])
}

/// A user who clicked "我想要" on an item (意向人 + Waiting List, unified).
model ItemInterest {
  id        String   @id @default(cuid())
  itemId    String
  userId    String
  message   String?
  createdAt DateTime @default(now())

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([itemId, userId])
  @@index([itemId, createdAt])
}

/// The in-progress/completed deal after a seller chooses a buyer.
model ItemDeal {
  id                String         @id @default(cuid())
  itemId            String         @unique
  sellerId          String
  buyerId           String
  status            ItemDealStatus @default(PENDING)
  firstConfirmerId  String?
  firstConfirmedAt  DateTime?
  completedAt       DateTime?
  cancelledById     String?
  cancelledAt       DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  item   Item @relation(fields: [itemId], references: [id], onDelete: Cascade)
  seller User @relation("ItemDealSeller", fields: [sellerId], references: [id], onDelete: Cascade)
  buyer  User @relation("ItemDealBuyer", fields: [buyerId], references: [id], onDelete: Cascade)

  @@index([sellerId])
  @@index([buyerId])
}

enum ItemDealStatus {
  PENDING
  COMPLETED
  CANCELLED
}

/// 收藏(多态:targetType + targetId 指向 Item/Service/Need,无 FK,应用层解析)。
model Favorite {
  id         String              @id @default(cuid())
  userId     String
  targetType FavoriteTargetType
  targetId   String
  createdAt  DateTime            @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, targetType, targetId])
  @@index([userId])
  @@index([targetType, targetId])
}

enum FavoriteTargetType {
  ITEM
  SERVICE
  NEED
}

// ───────────────────────── Service panel (咨询服务) ─────────────────────────

enum ServiceStatus {
  ACTIVE
  PAUSED
  CLOSED
}

model Service {
  id                String          @id @default(cuid())
  providerId        String
  title             String
  description       String
  qualification     String
  proofImageKeys    String[]
  categories        String[]
  formats           String[]
  durationTier      String?
  price             String
  contactInfo       String
  contactVisibility ContactVisibility @default(VERIFIED_ONLY)
  status            ServiceStatus   @default(ACTIVE)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  deletedAt         DateTime?

  provider User           @relation(fields: [providerId], references: [id], onDelete: Cascade)
  slots    ServiceSlot[]
  bookings Booking[]

  @@index([status, createdAt])
  @@index([providerId])
}

/// Manually-added bookable time windows (MVP: manual add only, per PRD §4.3 / MVP note).
model ServiceSlot {
  id        String   @id @default(cuid())
  serviceId String
  startAt   DateTime
  endAt     DateTime
  createdAt DateTime @default(now())

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, startAt, endAt])
  @@index([serviceId, startAt])
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLING
  COMPLETED
  REJECTED
  CANCELLED
}

/// A client's appointment for a service slot.
model Booking {
  id                 String        @id @default(cuid())
  serviceId          String
  slotId             String?
  slotStart          DateTime
  slotEnd            DateTime
  clientId           String
  note               String
  status             BookingStatus @default(PENDING)
  rejectReason       String?
  firstConfirmerId   String?
  firstConfirmedAt   DateTime?
  completedAt        DateTime?
  cancelledById      String?
  cancelledAt        DateTime?
  /// null = no cancel-in-flight / no-fault; true = 免责 agreed; false = disagreed → violation for canceller
  liabilityAgreed    Boolean?
  liabilityDecidedAt DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  client  User    @relation("BookingClient", fields: [clientId], references: [id], onDelete: Cascade)

  @@index([serviceId, status])
  @@index([clientId, status])
  @@index([status, firstConfirmedAt])
}

enum ExpectedTime {
  ASAP
  THIS_WEEK
  TWO_WEEKS
  FLEXIBLE
}

enum NeedStatus {
  OPEN
  PAUSED
  CLOSED
}

model Need {
  id                String          @id @default(cuid())
  requesterId       String
  title             String
  description       String
  expectedProfile   String?
  reward            String
  expectedTime      ExpectedTime
  formatPreference  String
  category          String
  contactInfo       String
  contactVisibility ContactVisibility @default(VERIFIED_ONLY)
  status            NeedStatus      @default(OPEN)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  deletedAt         DateTime?

  requester User         @relation(fields: [requesterId], references: [id], onDelete: Cascade)
  matches   NeedMatch[]

  @@index([status, createdAt])
  @@index([requesterId])
}

enum NeedMatchStatus {
  APPLIED
  MATCHED
  CANCELLING
  COMPLETED
  CANCELLED
  NOT_SELECTED
}

/// A provider's application to a need (应征) and the resulting match.
model NeedMatch {
  id                 String          @id @default(cuid())
  needId             String
  providerId         String
  message            String
  status             NeedMatchStatus @default(APPLIED)
  firstConfirmerId   String?
  firstConfirmedAt   DateTime?
  matchedAt          DateTime?
  completedAt        DateTime?
  cancelledById      String?
  cancelledAt        DateTime?
  liabilityAgreed    Boolean?
  liabilityDecidedAt DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  need     Need @relation(fields: [needId], references: [id], onDelete: Cascade)
  provider User @relation("NeedMatchProvider", fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([needId, providerId])
  @@index([needId, status])
  @@index([providerId, status])
  @@index([status, firstConfirmedAt])
}

// ───────────────────────── Reviews (交易评价) ─────────────────────────
// dealType + dealId is a polymorphic link (no FK): resolve the source table in
// application code based on dealType. One review per (dealType, dealId, reviewer).

enum DealType {
  ITEM
  BOOKING
  NEED_MATCH
}

model Review {
  id          String   @id @default(cuid())
  dealType    DealType
  dealId      String
  reviewerId  String
  revieweeId  String
  rating      Int
  content     String?
  /// 提交即公开:createReview 写入时即 revealed=true。@default(false) 仅为遗留兜底
  /// (旧双盲遗留行 + 30 天 auto-reveal cron 兜底公开任何遗漏);新评价不受其影响。
  revealed    Boolean  @default(false)
  revealedAt  DateTime?
  createdAt   DateTime @default(now())

  reviewer User @relation("ReviewReviewer", fields: [reviewerId], references: [id], onDelete: Cascade)
  reviewee User @relation("ReviewReviewee", fields: [revieweeId], references: [id], onDelete: Cascade)

  @@unique([dealType, dealId, reviewerId])
  @@index([revieweeId, revealed])
}

// ───────────────────────── Reports (举报) ─────────────────────────
// targetType + targetId is a polymorphic link (no FK): resolve in app code.

enum ReportTargetType {
  ITEM
  SERVICE
  NEED
  USER
}

enum ReportReason {
  FALSE_INFO
  SUSPECTED_FRAUD
  INAPPROPRIATE
  INVALID_CONTACT
  OTHER
}

enum ReportStatus {
  PENDING
  RESOLVED
}

enum ReportAction {
  NONE
  WARNING
  TAKEDOWN
  BAN
}

model Report {
  id          String           @id @default(cuid())
  reporterId  String
  targetType  ReportTargetType
  targetId    String
  reason      ReportReason
  description String?
  status      ReportStatus     @default(PENDING)
  action      ReportAction?
  resolverId  String?
  resolvedAt  DateTime?
  createdAt   DateTime         @default(now())

  reporter User @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([targetType, targetId])
}

// ───────────────────────── Feedback (用户反馈信箱) ─────────────────────────
// 用户向开发者提交问题/建议;管理员可在 /admin/feedback 查看、回复(站内通知)。
// 与 Report(违规举报)不同:面向开发者、不绑定具体目标、轻量。

enum FeedbackCategory {
  BUG
  FEATURE
  USABILITY
  OTHER
}

enum FeedbackStatus {
  PENDING
  REVIEWED
  RESOLVED
}

model Feedback {
  id           String           @id @default(cuid())
  userId       String
  category     FeedbackCategory
  content      String
  contact      String?
  status       FeedbackStatus   @default(PENDING)
  reply        String?
  reviewedById String?
  reviewedAt   DateTime?
  createdAt    DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
}

// ───────────────────────── Violations (违规) ─────────────────────────

enum ViolationSource {
  MANUAL
  BOOKING_CANCEL
  MATCH_CANCEL
}

model Violation {
  id        String           @id @default(cuid())
  userId    String
  source    ViolationSource
  reason    String
  reference String?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// ───────────────────────── Messages (站内私信) ─────────────────────────
// 把原本"一次性的"意向/预约/应征留言,升级为可在站内多轮沟通的私信。
// 不做独立聊天窗:挂在具体交易上下文(物品/服务/需求)上,仅"交易关系方"之间可见,
// 在详情页"沟通留言"区展示;新消息通过 Notification(type="message")送达对方。
// contextType + contextId 是多态链接(无 FK):在应用层按 contextType 解析到
// Item/Service/Need。一对用户的会话 = 同 (contextType, contextId) 下双方互发的消息。

enum MessageContextType {
  ITEM
  SERVICE
  NEED
}

model Message {
  id          String             @id @default(cuid())
  contextType MessageContextType
  contextId   String
  senderId    String
  recipientId String
  body        String
  createdAt   DateTime           @default(now())

  sender    User @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipient User @relation("MessageRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([contextType, contextId])
  @@index([recipientId, createdAt])
}
